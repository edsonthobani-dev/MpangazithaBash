@model List<MpangazithaBash.DAL.Tbl_Cart>

@{
    ViewBag.Title = "Order History";
}

<div class="container" style="margin-top:30px;">
    <div class="page-header">
        <h2>My Order History</h2>
    </div>

    @if (Model.Count == 0)
    {
        <div class="alert alert-info">
            <i class="fa fa-info-circle"></i>
            You have no orders yet.
            <a href="@Url.Action("Index", "Home")">Start Shopping!</a>
        </div>
    }
    else
    {
        <table class="table table-bordered table-hover">
            <thead>
                <tr>
                    <th>Order No.</th>
                    <th>Product</th>
                    <th>Price</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td>@order.CartId</td>
                        <td>@order.Tbl_Product.ProductName</td>
                        <td>R @order.Tbl_Product.Price</td>
                        <td>
                            <span class="label label-primary">
                                @order.Tbl_CartStatus.CartStatus
                            </span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <a href="@Url.Action("Index", "Home")" class="btn btn-default">
        <i class="fa fa-arrow-left"></i> Continue Shopping
    </a>

</div>
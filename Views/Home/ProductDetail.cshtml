@model MpangazithaBash.DAL.Tbl_Product


@{
    ViewBag.Title = @Model.ProductName;
}

<div class="container" style="margin-top:30px;">

    <a href="@Url.Action("Index", "Home")" class="btn btn-default mb-3">
        <i class="fa fa-arrow-left"></i> Back to Products
    </a>

    <div class="row">

        <!-- PRODUCT IMAGE -->
        <div class="col-md-5">
            <img src="~/Images/@Model.ProductImage"
                 class="img-responsive"
                 style="width:100%; border-radius:4px; border:1px solid #eee;" />
        </div>

        <!-- PRODUCT INFO -->
        <div class="col-md-7">
            <h2>@Model.ProductName</h2>
            <hr />

            <h3 style="color:#2c3e50;">R @Model.Price</h3>

            <p>@Model.Description</p>

            <table class="table table-bordered" style="margin-top:20px;">
                <tr>
                    <td><strong>Category</strong></td>
                    <td>@Model.Tbl_Category.CategoryName</td>
                </tr>
                <tr>
                    <td><strong>Availability</strong></td>
                    <td>
                        @if (Model.Quantity > 0)
                        {
                            <span class="label label-success">In Stock (@Model.Quantity available)</span>
                        }
                        else
                        {
                            <span class="label label-danger">Out of Stock</span>
                        }
                    </td>
                </tr>
                <tr>
                    <td><strong>Status</strong></td>
                    <td>
                        @if (Model.IsFeatured == true)
                        {
                            <span class="label label-primary">New</span>
                        }
                        else
                        {
                            <span class="label label-default">Pre-Owned</span>
                        }
                    </td>
                </tr>
            </table>

            @if (Model.Quantity > 0)
            {
                using (Html.BeginForm("AddToCart", "Home",
                    new { productId = Model.ProductId }, FormMethod.Post))
                {
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="fa fa-shopping-cart"></i> Add to Cart
                    </button>
                }
            }
            else
            {
                <button class="btn btn-default btn-lg" disabled>
                    Out of Stock
                </button>
            }
        </div>

        <!-- MAIN IMAGE -->
        <div class="col-md-5">
            <img src="~/Images/@Model.ProductImage"
                 class="img-responsive"
                 id="mainImage"
                 style="width:100%; border-radius:4px; border:1px solid #eee;" />

            <!-- ADDITIONAL IMAGES -->
            @if (Model.Tbl_ProductImages.Count > 0)
            {
                <div style="margin-top:10px; display:flex; gap:10px; flex-wrap:wrap;">
                    <!-- main image thumbnail -->
                    <img src="~/Images/@Model.ProductImage"
                         onclick="document.getElementById('mainImage').src=this.src"
                         style="width:70px; height:70px; object-fit:cover; cursor:pointer; border:2px solid #2c3e50; border-radius:4px;" />

                    <!-- additional image thumbnails -->
                    @foreach (var img in Model.Tbl_ProductImages)
                    {
                        <img src="~/Images/@img.ImagePath"
                             onclick="document.getElementById('mainImage').src=this.src"
                             style="width:70px; height:70px; object-fit:cover; cursor:pointer; border:1px solid #eee; border-radius:4px;" />
                    }
                </div>
            }
        </div>

    </div>
</div>
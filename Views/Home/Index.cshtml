@model MpangazithaBash.Models.Home.HomeIndexViewModel
@using PagedList
@using PagedList.Mvc

@{
    ViewBag.Title = "Home Page";
}

<!-- CAROUSEL -->
<div id="themeSlider" class="carousel slide" data-bs-ride="carousel">

    <div class="carousel-indicators">
        <button data-bs-target="#themeSlider" data-bs-slide-to="0" class="active"></button>
        <button data-bs-target="#themeSlider" data-bs-slide-to="1"></button>
        <button data-bs-target="#themeSlider" data-bs-slide-to="2"></button>
    </div>

    <div class="carousel-inner">
        <div class="carousel-item active">
            <img src="~/images/NeverToFly.jpeg" class="slider-img">
            <div class="carousel-caption">
                <h3>Welcome to My Website</h3>
                <p>Discover our products and services.</p>
            </div>
        </div>

        <div class="carousel-item">
            <img src="~/images/Tracksuit.jpeg" class="slider-img">
            <div class="carousel-caption">
                <h3>Our Gallery</h3>
                <p>Browse our latest images.</p>
            </div>
        </div>

        <div class="carousel-item">
            <img src="~/images/RedScotty.jpeg" class="slider-img">
            <div class="carousel-caption">
                <h3>Contact Us</h3>
                <p>Get in touch with our team today.</p>
            </div>
        </div>
    </div>

    <button class="carousel-control-prev" type="button" data-bs-target="#themeSlider" data-bs-slide="prev">
        <span class="carousel-control-prev-icon"></span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#themeSlider" data-bs-slide="next">
        <span class="carousel-control-next-icon"></span>
    </button>

</div>

<div class="container">

    <!-- SEARCH BOX -->
    <div class="search-box">
        <h2>Search Product/Category</h2>
        @using (Html.BeginForm("Index", "Home", FormMethod.Get))
        {
            <div class="search-wrapper">
                <input type="text"
                       name="search"
                       class="inputComn houseText"
                       placeholder="Enter Keyword"
                       value="@ViewBag.Search" />
                <button type="submit" class="searchBtn">
                    <i class="fa fa-search"></i>
                </button>
            </div>
        }
    </div>

    <!-- PRODUCTS HEADER -->
    <div class="row">
        <div class="col-md-12">
            <div class="page-header">
                <h2>Our Product <small>Trending products</small></h2>
            </div>
        </div>
    </div>

    <!-- PRODUCT GRID -->
    <div class="row product-container">
        @foreach (var item in Model.listofProducts)
        {
            <div class="col-md-3 col-sm-3 col-xs-6">
                <div class="thumbnail product-item" style="height:300px">

                    @* ✅ Make image clickable *@
                    <a href="@Url.Action("ProductDetail", "Home", new { productId = item.ProductId })">
                        <img src="~/Images/@item.ProductImage"
                             class="img-responsive"
                             style="height:160px; width:100%; object-fit:cover;" />
                    </a>

                    <div class="caption">

                        @* ✅ Make name clickable *@
                        <h5>
                            <a href="@Url.Action("ProductDetail", "Home", new { productId = item.ProductId })"
                               style="color:#2c3e50; text-decoration:none;">
                                @item.ProductName
                            </a>
                        </h5>

                        <p>R @item.Price</p>

                        @if (item.Quantity > 0)
                        {
                            using (Html.BeginForm("AddToCart", "Home",
                                new { productId = item.ProductId }, FormMethod.Post))
                            {
                                <button type="submit" class="btn btn-primary btn-xs">
                                    <i class="fa fa-shopping-cart"></i> Add to Cart
                                </button>
                            }
                            <p>Available</p>
                        }
                        else
                        {
                            <p>Not Available</p>
                        }

                        <div class="product-item-badge">
                            @if (item.IsFeatured == true)
                            {
                                <span>New</span>
                            }
                            else
                            {
                                <span>Pre-Owned</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        
        }
    </div>

    <!-- PAGINATION -->
    <div class="row">
        <div class="col-md-12 text-center">
            @Html.PagedListPager(
                Model.listofProducts,
                page => Url.Action("Index", new
                     {
                    page,
                    search = Request.QueryString["search"]
                }),
                new PagedListRenderOptions
                     {
                    Display = PagedListDisplayMode.IfNeeded
                }
            )
        </div>
    </div>

</div>
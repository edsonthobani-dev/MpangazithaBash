@model MpangazithaBash.Models.Home.CheckoutDetail

@{
    ViewBag.Title = "Checkout";
}

<div class="container" style="margin-top:30px;">
    <h2>Checkout</h2>

    <div class="row">
        <!-- ORDER SUMMARY -->
        <div class="col-md-6">
            <div class="panel panel-default">
                <div class="panel-heading"><h3 class="panel-title">Order Summary</h3></div>
                <div class="panel-body">
                    <table class="table table-bordered">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th>Qty</th>
                                <th>Price</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Session["cart"] != null)
                            {
                                foreach (var cartItem in (List<MpangazithaBash.Models.Home.item>)Session["cart"])
                                {
                                    <tr>
                                        <td>@cartItem.tbl_product.ProductName</td>
                                        <td>@cartItem.Quantity</td>
                                        <td>R @(cartItem.tbl_product.Price * cartItem.Quantity)</td>
                                    </tr>
                                }
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="2"><strong>Total</strong></td>
                                <td>
                                    <strong>
                                        R @((Session["cart"] as List<MpangazithaBash.Models.Home.item>)
                                            .Sum(i => i.tbl_product.Price * i.Quantity))
                                    </strong>
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        <!-- CUSTOMER DETAILS -->
        <div class="col-md-6">
            <div class="panel panel-default">
                <div class="panel-heading"><h3 class="panel-title">Your Details</h3></div>
                <div class="panel-body">

                    @if (Session["member"] != null)
                    {
                        var member = (MpangazithaBash.DAL.Tbl_Member)Session["member"];
                        <!-- ✅ logged in - just show details and confirm button -->
                        <p><strong>Name:</strong> @member.FirstName @member.LastName</p>
                        <p><strong>Email:</strong> @member.Email</p>

                        using (Html.BeginForm("CheckoutDetails", "Home", FormMethod.Post))
                        {
                            @Html.HiddenFor(m => m.MemberId)
                            <button type="submit" class="btn btn-primary btn-block">
                                <i class="fa fa-check"></i> Confirm Order
                            </button>
                        }
                    }
                    else
                    {
                        <!-- ✅ not logged in - show form -->
                        using (Html.BeginForm("CheckoutDetails", "Home", FormMethod.Post))
                        {
                            @Html.HiddenFor(m => m.MemberId)

                            <div class="form-group">
                                <label>First Name</label>
                                @Html.TextBoxFor(m => m.FirstName, new { @class = "form-control", placeholder = "First Name" })
                                @Html.ValidationMessageFor(m => m.FirstName, "", new { @class = "text-danger" })
                            </div>

                            <div class="form-group">
                                <label>Last Name</label>
                                @Html.TextBoxFor(m => m.LastName, new { @class = "form-control", placeholder = "Last Name" })
                                @Html.ValidationMessageFor(m => m.LastName, "", new { @class = "text-danger" })
                            </div>

                            <div class="form-group">
                                <label>Email</label>
                                @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "Email" })
                                @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
                            </div>

                            <div class="form-group">
                                <label>Password</label>
                                @Html.PasswordFor(m => m.Password, new { @class = "form-control", placeholder = "Password" })
                                @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
                            </div>

                            <button type="submit" class="btn btn-primary btn-block">
                                <i class="fa fa-check"></i> Place Order
                            </button>
                        }
                    }

                    <a href="@Url.Action("Cart", "Home")" class="btn btn-danger btn-block" style="margin-top:10px;">
                        <i class="fa fa-arrow-left"></i> Back to Cart
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>